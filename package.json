{
  "name": "bead-pattern-studio",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "predev": "npm run worker:build",
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "prebuild": "npm run worker:build",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "premobile:build": "npm run worker:build",
    "mobile:build": "vite build --config vite.mobile.config.ts",
    "mobile:sync": "npm run mobile:build && cap sync ios",
    "ios:open": "npm run mobile:sync && cap open ios",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "worker:build": "node scripts/build-pattern-worker.mjs",
    "worker:check": "node scripts/build-pattern-worker.mjs --check",
    "test": "npm run worker:check && npm run build && node --test tests/rendered-html.test.mjs && tsx --test tests/pattern-core.test.ts",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern public/pattern-generation-worker.js",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.2",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.2",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.3",
    "drizzle-orm": "0.45.2",
    "next": "16.2.10",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.19"
    }
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "esbuild": "0.27.7",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
